# ===== REQUIRED =====

# Database
DATABASE_URL=mysql://user:password@localhost:3306/rifleclub

# JWT
JWT_SECRET=generate-a-256-bit-random-string-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Razorpay (LIVE keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email (Hostinger SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_email_password

# Admin seed
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=a-strong-admin-password

# App
PORT=3001
NODE_ENV=production
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Club branding
CLUB_NAME=National Capital Rifle Club
CLUB_EMAIL=info@yourdomain.com
CLUB_LOGO_URL=https://yourdomain.com/logo.png

# ===== OPTIONAL =====

# Storage (defaults to ./storage locally, /tmp on Vercel)
# STORAGE_PATH=./storage
# LOG_PATH=./logs

# Vercel Cron secret (auto-set by Vercel, also set in Vercel dashboard)
# CRON_SECRET=generate-a-random-string

# Google OAuth (for NextAuth on frontend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Storage paths (defaults shown)
STORAGE_PATH=./storage
LOG_PATH=./logs
